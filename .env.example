# Template for environment configuration
# Copy to .env.dev, .env.staging, or .env.prod and fill in values
# Never commit files with actual secrets

## API Configuration
API_FOOTBALL_KEY=your_api_football_key_here

## Database Configuration
DATABASE_URL=postgresql+psycopg://username:password@host:5432/database_name

## Email Configuration
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=noreply@ballwork.com
EMAIL_USE_TLS=false

## Scheduler Configuration
RUN_SCHEDULER=false

## Logging
LOG_LEVEL=INFO
